            for k, v in [('NewUI', 'TRUE'), ('OldUI', 'FALSE'), ('TextureCache', 'FALSE'), ('WindowedMode', 'FALSE')]: c.set('Defaults', k, v)
            for k, v in [('MaxFPS', '144'), ('MaxBGFPS', '60'), ('NoFPSLimiter', 'FALSE')]: c.set('Options', k, v)
