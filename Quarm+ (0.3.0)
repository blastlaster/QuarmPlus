    def check_and_update(self, app, ver, repo, idir):
        self.update_progress(0)
        try:
            url = f"https://api.github.com/repos/{repo}/releases/{'latest' if ver == 'Latest' else f'tags/{ver}'}"
            r = requests.get(url, timeout=5)
            if r.status_code != 200: self.log_message(f"Fetch failed: {r.status_code}", "red"); return False
            rel = r.json()
            if not rel.get('assets'): self.log_message("No assets.", "red"); return False
            dp = os.path.join(idir, f"{app.lower()}_{ver}.zip")
            if not self.download_with_retry(rel['assets'][0]['browser_download_url'], dp): return False
            self.log_message(f"Extracting {app}...")
            pui = {}; ptga = {}
            if app == "Zeal":
                ud = os.path.join(idir, "uifiles")
                if os.path.exists(ud):
                    for i in os.listdir(ud):
                        ip = os.path.join(ud, i)
                        if os.path.isdir(ip) and i != "zeal": tp = os.path.join(idir, f"temp_ui_{i}"); shutil.move(ip, tp); pui[i] = tp
                ptga = self.preserve_custom_tga_files(idir)
            tmp = os.path.join(idir, f"tmp_{app}_{ver}"); os.makedirs(tmp, exist_ok=True)
            try:
                with zipfile.ZipFile(dp, 'r') as z: z.extractall(tmp)
            except zipfile.BadZipFile as e: self.log_message(f"Bad ZIP: {e}", "red"); shutil.rmtree(tmp, True); os.remove(dp); return False
            items = os.listdir(tmp)
            if len(items) == 1 and os.path.isdir(os.path.join(tmp, items[0])):
                sd = os.path.join(tmp, items[0])
                for i in os.listdir(sd):
                    s, d = os.path.join(sd, i), os.path.join(idir, i)
                    if os.path.exists(d): shutil.rmtree(d) if os.path.isdir(d) else os.remove(d)
                    shutil.move(s, d)
            else:
                for i in items:
                    s, d = os.path.join(tmp, i), os.path.join(idir, i)
                    if os.path.exists(d): shutil.rmtree(d) if os.path.isdir(d) else os.remove(d)
                    shutil.move(s, d)
            shutil.rmtree(tmp, True); os.remove(dp)
            if app == "Zeal":
                ud = os.path.join(idir, "uifiles"); os.makedirs(ud, exist_ok=True)
                for n, tp in pui.items():
                    dp2 = os.path.join(ud, n)
                    if os.path.exists(dp2): shutil.rmtree(dp2)
                    shutil.move(tp, dp2)
                self.restore_custom_tga_files(idir, ptga)
                if any(not os.path.exists(os.path.join(idir, f)) for f in ["eqgame.exe", "Zeal.asi"]): self.log_message("Missing files.", "red"); return False
            self.update_progress(100); return True
        except Exception as e: self.log_message(f"Error: {e}", "red"); return False

