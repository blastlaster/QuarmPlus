            self.quarmtool_dir.set(d); self.save_settings(); self.log_message(f"QuarmTool dir: {d}", "green")
            self.version_cache.pop("quarmtool_versions", None); self.initial_version_check(); self.update_quarmtool_button()

    # -- Run --
    def run_quarmtool(self):
        d = self.quarmtool_dir.get()
        if not d: self.log_message("Set QuarmTool directory.", "red"); return
        p = os.path.join(d, "QuarmTool.exe")
        if not os.path.exists(p): self.log_message("QuarmTool.exe not found.", "red"); return
        try: subprocess.Popen(p, cwd=d); self.log_message("Started QuarmTool", "green")
        except Exception as e: self.log_message(str(e), "red")

    def run_project_quarm(self):
        d = self.zeal_dir.get()
        if not d: self.log_message("Set Zeal directory.", "red"); return
        p = os.path.join(d, "eqgame.exe")
        if not os.path.exists(p): self.log_message("eqgame.exe not found.", "red"); return
        try: subprocess.Popen(p, cwd=d); self.log_message("Started Project Quarm", "green")
        except Exception as e: self.log_message(str(e), "red")

    def run_quarm_patcher(self):
        d = self.zeal_dir.get()
        if not d: self.log_message("Set Zeal directory.", "red"); return
        p = os.path.join(d, "eqemupatcher.exe")
        if not os.path.exists(p): self.log_message("Patcher not installed.", "red"); return
        try: subprocess.Popen(p, cwd=d, creationflags=subprocess.CREATE_NO_WINDOW); self.log_message("Started Patcher", "green")
        except Exception as e: self.log_message(str(e), "red")

    # -- Updates --
    def check_and_install_updates(self):
        self.log_message("Checking for updates..."); self.update_progress(0)
        try:
            ups = self._check_all_updates()
            self.log_message(("Update(s): " + ", ".join(ups) + " - Click yellow buttons.") if ups else "All up to date!", "#ADD8E6" if ups else "green")
        except Exception as e: self.log_message(str(e), "red")
        finally: self.update_progress(100); self.update_zeal_button(); self.update_quarmtool_button(); self.update_quarmplus_button(); self.update_patcher_button(); self.update_ui_selection()

    def update_zeal(self):
        zd = self.zeal_dir.get()
        if not zd: self.log_message("Set Zeal directory.", "red"); return
        sel = self.selected_zeal_version.get()
        if sel in ("Unknown", "Loading...", ""): self.log_message("Unknown version.", "red"); return
        if not self.is_zeal_installed(): self.ui_versions.pop("Zeal", None)
        self.log_message(f"Installing Zeal {sel}..."); self.update_progress(0)
        if self.check_and_update("Zeal", sel, "CoastalRedwood/Zeal", zd) and self.is_zeal_installed():
            r = sel.lstrip("v"); self.ui_versions["Zeal"] = {"normalized": self.normalize_version(sel), "raw": r}; self.selected_zeal_version.set(r); self.save_settings(); self.log_message(f"Updated Zeal to {sel}", "green")
        else: self.log_message("Zeal update failed.", "red")
        self.update_progress(100); self.update_zeal_button()

