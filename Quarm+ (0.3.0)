    INCOMPATIBLE_UIS = ["Infiniti-Blue", "Nemesis", "poweroftwo", "QQ", "TK_Steamworks", "vert", "WizModRyo"]

    def _has_incompatible_uis(self):
        """Check if any known incompatible UI folders exist in uifiles/."""
        zd = self.zeal_dir.get()
        if not zd: return False
        uifiles = os.path.join(zd, "uifiles")
        if not os.path.isdir(uifiles): return False
        existing = {d.lower() for d in os.listdir(uifiles) if os.path.isdir(os.path.join(uifiles, d))}
        return any(name.lower() in existing for name in self.INCOMPATIBLE_UIS)

    def remove_incompatible_uis(self):
        """Delete known incompatible UI folders from uifiles/."""
        zd = self.zeal_dir.get()
        if not zd: self.log_message("Set Zeal directory.", "red"); return
        uifiles = os.path.join(zd, "uifiles")
        if not os.path.isdir(uifiles): self.log_message("No uifiles folder found.", "yellow"); return
        # Build a case-insensitive lookup of what's on disk
        on_disk = {d.lower(): d for d in os.listdir(uifiles) if os.path.isdir(os.path.join(uifiles, d))}
        removed = []
        for name in self.INCOMPATIBLE_UIS:
            actual = on_disk.get(name.lower())
            if actual:
                target = os.path.join(uifiles, actual)
                try:
                    shutil.rmtree(target)
                    removed.append(actual)
                except Exception as e:
                    self.log_message(f"Could not remove {actual}: {e}", "red")
        if removed:
            self.log_message(f"Removed {len(removed)} incompatible UI(s): {', '.join(removed)}", "green")
            self.after(5000, lambda: self.log_message("Ready to play!", "green"))
        else:
            self.log_message("No incompatible UIs found.", "green")
        self.update_ui_selection()
    def get_cached_version(self, ck, fn):
        if ck in self.version_cache:
            v, t = self.version_cache[ck]
            if time.time() - t < CACHE_DURATION: return v
        try:
            v = fn()
            if v: self.version_cache[ck] = (v, time.time())
            return v
        except Exception: return {"full": [], "beta": []} if ck == "zeal_versions" else []

    def fetch_versions(self, repo):
        for a in range(3):
            try:
                r = requests.get(f"https://api.github.com/repos/{repo}/releases", timeout=5)
                if r.status_code == 200:
                    rl = r.json(); st = [x['tag_name'] for x in rl if not x.get('prerelease') and not any(t in x['tag_name'].lower() for t in ('beta', 'alpha', 'rc'))]
                    return {"full": st, "beta": []} if repo == "CoastalRedwood/Zeal" else st
                return {"full": [], "beta": []} if repo == "CoastalRedwood/Zeal" else []
            except Exception:
                if a == 2: return {"full": [], "beta": []} if repo == "CoastalRedwood/Zeal" else []
            time.sleep(2 ** a)
        return {"full": [], "beta": []} if repo == "CoastalRedwood/Zeal" else []

    def normalize_version(self, vs):
        if not isinstance(vs, str) or not vs or vs in ("Unknown", "Loading...", "Latest"): return "0.0.0"
        p = re.sub(r'[^0-9.]', '', vs.split('-')[0].lstrip('v')).split('.')
        while len(p) < 3: p.append('0')
        return '.'.join(p[:3])

    # -- Download --
    def download_with_retry(self, url, path, retries=3):
        for a in range(retries):
            try:
                self.log_message(f"Downloading ({a+1}/{retries})..."); self.update_progress(0)
                r = requests.get(url, stream=True, timeout=30, allow_redirects=True)
                if r.status_code != 200: raise requests.exceptions.RequestException(f"HTTP {r.status_code}")
                total = int(r.headers.get('content-length', 0)); dl = 0
                with open(path, 'wb') as f:
                    for ch in r.iter_content(8192):
                        if ch: f.write(ch); dl += len(ch)
                        if total: self.update_progress(dl / total * 100)
                return True
            except Exception as e:
                self.log_message(f"Attempt {a+1} failed: {e}", "red")
                if a == retries - 1: return False
                time.sleep(2 ** a)
        return False

