    def show_version_dropdown(self, app, pf):
        vs = self.zeal_versions if app == "Zeal" else self.quarmtool_versions
        if not vs: self.log_message(f"No versions for {app}.", "yellow"); return
        m = tk.Menu(self, tearoff=0, bg="black", fg="white", font=("Segoe UI", 10))
        cv = self.ui_versions.get(app, {}).get("raw")
        for v in vs:
            lb = f"{v} *" if cv and v.lstrip("v") == cv.lstrip("v") else v
            m.add_command(label=lb, command=lambda ver=v: self.select_version(app, ver))
        try:
            b = pf.winfo_children()[-1]; m.tk_popup(b.winfo_rootx(), b.winfo_rooty() + b.winfo_height())
        except tk.TclError: pass

