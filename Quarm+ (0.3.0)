    def _parse_custom_ui_url(self, url, dn):
        url = url.strip(); lo = url.lower()
        m = re.match(r'https?://github\.com/user-attachments/files/\d+/(.+)$', url, re.IGNORECASE)
        if m: fn = m.group(1); return {"name": dn or self._name_from_filename(fn), "url": url, "type": f"direct_{self._ext_from_filename(fn)}"}
        m = re.match(r'https?://github\.com/[^/]+/[^/]+/releases/download/[^/]+/(.+)$', url, re.IGNORECASE)
        if m: fn = m.group(1); return {"name": dn or self._name_from_filename(fn), "url": url, "type": f"direct_{self._ext_from_filename(fn)}"}
        if 'github.com' in lo and '?raw=true' in lo:
            fn = os.path.basename(urlparse(url).path); return {"name": dn or self._name_from_filename(fn), "url": url, "type": f"direct_{self._ext_from_filename(fn)}"}
        m = re.match(r'https?://github\.com/([^/]+)/([^/]+?)(?:\.git)?(?:/(?:tree|blob|releases)?.*)?$', url)
        if m and m.group(1).lower() != "user-attachments":
            o, rp = m.group(1), m.group(2); return {"name": dn or rp, "url": f"https://api.github.com/repos/{o}/{rp}/releases/latest", "type": "github", "repo": f"{o}/{rp}"}
        if 'eqinterface.com' in lo:
            p = urlparse(url); dl = url.replace('fileinfo.php', 'download.php') if 'fileinfo.php' in p.path else url
            eid = parse_qs(p.query).get('id', [''])[0]; return {"name": dn or (f"EQInterface-{eid}" if eid else "EQInterface UI"), "url": dl, "type": "eqinterface"}
        pl = urlparse(url).path.lower()
        if pl.endswith('.zip'): return {"name": dn or self._name_from_url(url), "url": url, "type": "direct_zip"}
        if pl.endswith('.7z'): return {"name": dn or self._name_from_url(url), "url": url, "type": "direct_7z"}
        if dn: return {"name": dn, "url": url, "type": "direct_zip"}
        return None

    @staticmethod
    def _ext_from_filename(fn): return "7z" if fn.lower().endswith('.7z') else "zip"
    @staticmethod
    def _name_from_filename(fn):
        n = os.path.splitext(fn)[0]; return re.sub(r'[-_]?(latest|release|final)$', '', n, flags=re.IGNORECASE).strip('-_ ') or "CustomUI"
    def _name_from_url(self, url): return self._name_from_filename(os.path.basename(urlparse(url).path))

