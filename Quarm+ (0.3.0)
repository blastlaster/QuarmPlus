    # -- Settings --
    def load_settings(self):
        defs = {"version": APP_VERSION, "zeal_dir": "", "quarmtool_dir": "", "ui_versions": {}, "section_states": {}, "custom_uis": {}}
        if os.path.exists(settings_file):
            try:
                with open(settings_file) as f: ld = json.load(f)
                if ld.get("version") != APP_VERSION: return self.migrate_settings(ld, defs)
                for k, v in defs.items():
                    if k not in ld: ld[k] = v
                return ld
            except Exception:
                return defs
        return defs

    def migrate_settings(self, old, defs):
        m = defs.copy()
        for k in ["zeal_dir", "quarmtool_dir", "ui_versions", "section_states", "custom_uis"]:
            if k in old: m[k] = old[k]
        m.setdefault("custom_uis", {}); m["version"] = APP_VERSION; return m

    def save_settings(self):
        try:
            with open(settings_file, 'w') as f:
                json.dump({"version": APP_VERSION, "zeal_dir": self.zeal_dir.get(), "quarmtool_dir": self.quarmtool_dir.get(), "ui_versions": self.ui_versions, "section_states": self.section_states, "custom_uis": self.custom_uis}, f, indent=4)
        except Exception as e: self.log_message(f"Save error: {e}", "red")

    # -- Startup --
    def perform_initial_setup(self):
        self.initialize_ui_versions(); self.initial_version_check(); self.check_for_updates_on_start()
        self.update_zeal_button(); self.update_quarmtool_button(); self.update_quarmplus_button(); self.update_patcher_button(); self.update_ui_selection()

    def initialize_ui_versions(self):
        if not self.zeal_dir.get(): return
        for name, url in [("NillipussUI_1080p", "https://api.github.com/repos/NilliP/NillipussUI_1080p/releases/latest"), ("NillipussUI_1440p", "https://api.github.com/repos/NilliP/NillipussUI_1440p/releases/latest")]:
            if self.is_ui_installed(name, self.zeal_dir.get()) and name not in self.ui_versions:
                try: r = requests.get(url, timeout=5); r.raise_for_status(); raw = r.json().get("tag_name", "0.0.0")
                except Exception: raw = "0.0.0"
                self.ui_versions[name] = {"raw": raw, "normalized": self.normalize_version(raw)}
        self.save_settings()

    def initial_version_check(self):
        try:
            zd = self.get_cached_version("zeal_versions", lambda: self.fetch_versions("CoastalRedwood/Zeal"))
            self.zeal_versions = zd["full"]; self.latest_full = zd["full"][0] if zd["full"] else "Unknown"
            cz = self.ui_versions.get("Zeal", {}).get("raw")
            self.selected_zeal_version.set(cz if self.is_zeal_installed() and cz else (self.latest_full if self.latest_full != "Unknown" else "Unknown"))
            self.quarmtool_versions = self.get_cached_version("quarmtool_versions", lambda: self.fetch_versions("EJWellman/QuarmTool"))
            cq = self.ui_versions.get("QuarmTool", {}).get("raw")
            self.selected_quarmtool_version.set(cq if self.is_quarmtool_installed() and cq else (self.quarmtool_versions[0] if self.quarmtool_versions else "Unknown"))
        except Exception as e: self.log_message(f"Version check error: {e}", "red")
        self.update_zeal_button(); self.update_quarmtool_button()

    def check_for_updates_on_start(self):
        self.update_progress(0)
        try:
            ups = self._check_all_updates()
            self.log_message(("Update(s): " + ", ".join(ups) + "\nClick yellow buttons to update") if ups else "Up to date - Ready to play!", "#ADD8E6" if ups else "green")
        except Exception as e: self.log_message(f"Error: {e}", "red")
        finally: self.update_progress(100); self.update_zeal_button(); self.update_quarmtool_button(); self.update_quarmplus_button()

    def _check_all_updates(self):
        ups = []; self.version_cache.pop("zeal_versions", None); self.version_cache.pop("quarmtool_versions", None)
        if not self.is_zeal_installed():
            self.ui_versions.pop("Zeal", None); ups.append("Zeal")
        else:
            zd = self.get_cached_version("zeal_versions", lambda: self.fetch_versions("CoastalRedwood/Zeal"))
            self.zeal_versions = zd["full"]; self.latest_full = zd["full"][0] if zd["full"] else "Unknown"
            cn = self.ui_versions.get("Zeal", {}).get("normalized", "0.0.0")
            if self.latest_full != "Unknown" and version.parse(self.normalize_version(self.latest_full)) > version.parse(cn): ups.append("Zeal")
        if not self.is_quarmtool_installed():
            self.ui_versions.pop("QuarmTool", None); ups.append("QuarmTool")
        else:
            self.quarmtool_versions = self.get_cached_version("quarmtool_versions", lambda: self.fetch_versions("EJWellman/QuarmTool"))
            cn = self.ui_versions.get("QuarmTool", {}).get("normalized", "0.0.0")
            lq = self.quarmtool_versions[0] if self.quarmtool_versions else "Unknown"
            if lq != "Unknown" and version.parse(self.normalize_version(lq)) > version.parse(cn): ups.append("QuarmTool")
        try:
            r = requests.get("https://api.github.com/repos/blastlaster/QuarmPlus/releases/latest", timeout=5)
            if r.status_code == 200:
                lv = r.json()['tag_name']; self.quarmplus_version_var.set(lv)
                if version.parse(lv) > version.parse(APP_VERSION): ups.append("Quarm+")
        except Exception: pass
        return ups

    # -- Buttons --
    def update_zeal_button(self):
        if not self.zeal_update_button: return
        zd = self.get_cached_version("zeal_versions", lambda: self.fetch_versions("CoastalRedwood/Zeal"))
        lat = zd["full"][0] if zd["full"] else "Unknown"; ln = self.normalize_version(lat) if lat != "Unknown" else "0.0.0"
        sel = self.selected_zeal_version.get(); cur = self.ui_versions.get("Zeal", {}).get("raw", "Unknown"); cn = self.ui_versions.get("Zeal", {}).get("normalized", "0.0.0")
        if sel == "Latest": sel = lat; self.selected_zeal_version.set(sel)
        if not self.is_zeal_installed(): self.zeal_update_button.config(text=f"Install Zeal ({sel})", bg="yellow", fg="black", activebackground="yellow")
        elif sel in ("Unknown", "Loading...", ""): self.zeal_update_button.config(text="Zeal (?)", bg="#0078D4", fg="white", activebackground="#106EBE")
        else:
            sn = self.normalize_version(sel); sr, cr, lr = sel.lstrip("v"), cur.lstrip("v"), lat.lstrip("v")
            if cn == ln and cr == lr and sn == cn: self.zeal_update_button.config(text=f"Zeal ({cur}) \u2611", bg="#0078D4", fg="white", activebackground="#106EBE")
            elif sn == cn and sr == cr: self.zeal_update_button.config(text=f"Zeal ({cur})", bg="#FF4040", fg="white", activebackground="#CC3333")
            elif version.parse(sn) < version.parse(cn): self.zeal_update_button.config(text=f"Install Zeal ({sel})", bg="#FF9913", fg="black", activebackground="#FF9913")
            else: self.zeal_update_button.config(text=f"Install Zeal ({sel})", bg="yellow", fg="black", activebackground="yellow")

    def update_quarmtool_button(self):
        if not self.quarmtool_update_button: return
        sel = self.selected_quarmtool_version.get(); cur = self.ui_versions.get("QuarmTool", {}).get("raw", "Unknown"); cn = self.ui_versions.get("QuarmTool", {}).get("normalized", "0.0.0")
        lq = self.quarmtool_versions[0] if self.quarmtool_versions else "Unknown"; ln = self.normalize_version(lq) if lq != "Unknown" else "0.0.0"
        if not self.is_quarmtool_installed():
            if sel in ("Unknown", "Loading...", ""): sel = lq; self.selected_quarmtool_version.set(sel)
            self.quarmtool_update_button.config(text=f"Install QuarmTool ({sel})", bg="yellow", fg="black", activebackground="yellow")
        elif sel in ("Unknown", "Loading...", ""): self.quarmtool_update_button.config(text="QuarmTool (?)", bg="#0078D4", fg="white", activebackground="#106EBE")
        else:
            sn = self.normalize_version(sel); sr, cr, lr = sel.lstrip("v"), cur.lstrip("v"), lq.lstrip("v")
            if sn == cn and sr == cr and cn == ln: self.quarmtool_update_button.config(text=f"QuarmTool ({cur}) \u2611", bg="#0078D4", fg="white", activebackground="#106EBE")
            elif sn == cn and sr == cr: self.quarmtool_update_button.config(text=f"QuarmTool ({cur})", bg="#FF4040", fg="white", activebackground="#CC3333")
            elif version.parse(sn) < version.parse(cn): self.quarmtool_update_button.config(text=f"Install QuarmTool ({sel})", bg="#FF9913", fg="black", activebackground="#FF9913")
            else: self.quarmtool_update_button.config(text=f"Install QuarmTool ({sel})", bg="yellow", fg="black", activebackground="yellow")

